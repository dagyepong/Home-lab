# ========== IMMICH ==========
IMMICH_VERSION=release
UPLOAD_LOCATION=/media/dfr
DB_DATA_LOCATION=./postgres
DB_PASSWORD=your_strong_db_password_here
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=immich_redis

# Force binding – fixes 502 errors
HOST=0.0.0.0
IMMICH_HOST=0.0.0.0
IMMICH_SERVER_HOST=0.0.0.0
IMMICH_SERVER__HOST=0.0.0.0
NESTJS_HOST=0.0.0.0

# ========== POCKET ID ==========
# Critical: use APP_URL (not PUBLIC_APP_URL) for modern versions
APP_URL=https://pocketid.linuxpad.blog
TRUST_PROXY=true
ENCRYPTION_KEY=your-32-byte-hex-key-here  # Generate with: openssl rand -hex 32

# Optional: disable heartbeat (removes 429 errors)
DISABLE_HEARTBEAT=true

# ========== IMMICH OIDC (Pocket ID client) ==========
# These come from the OIDC client you create inside Pocket ID
POCKET_ID_ISSUER=https://pocketid.linuxpad.blog
POCKET_ID_CLIENT_ID=your-client-id
POCKET_ID_CLIENT_SECRET=your-client-secret