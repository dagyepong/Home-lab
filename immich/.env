# Immich
IMMICH_VERSION=release
UPLOAD_LOCATION=/media/dfr
DB_DATA_LOCATION=./postgres
DB_PASSWORD=yourStrongPassword123   # CHANGE THIS
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Because immich-server uses host network, DB and Redis are on localhost
DB_HOSTNAME=localhost
REDIS_HOSTNAME=localhost

# OIDC (Pocket ID)
POCKET_ID_ISSUER=https://pocketid.linuxpad.blog
POCKET_ID_CLIENT_ID=5fa4af59-f72c-46df-b872-c51301902230
POCKET_ID_CLIENT_SECRET=tUZC3G4XleTnim4gjl6d6lnNTJ1e43Wt

# Immich OIDC settings
IMMICH__OAUTH__ENABLED=true
IMMICH__OAUTH__ISSUER_URL=${POCKET_ID_ISSUER}
IMMICH__OAUTH__CLIENT_ID=${POCKET_ID_CLIENT_ID}
IMMICH__OAUTH__CLIENT_SECRET=${POCKET_ID_CLIENT_SECRET}
IMMICH__OAUTH__SCOPE=openid email profile
IMMICH__OAUTH__BUTTON_TEXT=Login with Pocket ID
IMMICH__OAUTH__AUTO_REGISTER=true

# Pocket ID
APP_URL=https://pocketid.linuxpad.blog
TRUST_PROXY=true
ENCRYPTION_KEY=openssl rand -hex 32  # generate once and hardcode
DISABLE_HEARTBEAT=true

POCKET_ID_ADMIN_EMAIL=replace_0606@gmail.com   # your admin email
PORT=80