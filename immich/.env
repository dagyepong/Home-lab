# Immich version – 'release' tracks the latest stable
IMMICH_VERSION=release

# Storage paths
UPLOAD_LOCATION=/media/dfr               # Absolute path for uploaded photos/videos
DB_DATA_LOCATION=./postgres              # Relative path for PostgreSQL data

# Database credentials – CHANGE THESE!
DB_PASSWORD=your_strong_password_here    # ← replace with a secure password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Redis host (internal Docker service name)
REDIS_HOSTNAME=immich_redis

# Force binding to all interfaces (fixes 502)
HOST=0.0.0.0
IMMICH_HOST=0.0.0.0
IMMICH_SERVER_HOST=0.0.0.0
IMMICH_SERVER__HOST=0.0.0.0
NESTJS_HOST=0.0.0.0