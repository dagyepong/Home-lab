# What to back up (subdirectories inside /backup)
BACKUP_SOURCES=/backup

# Backup filename pattern
BACKUP_FILENAME=backup-%Y-%m-%dT%H-%M-%S.tar.gz

# Schedule: daily at 2:00 AM
BACKUP_CRON_EXPRESSION=0 2 * * *

# Retention: keep backups for 14 days
BACKUP_RETENTION_DAYS=14

# (Optional) Encrypt backups with GPG
# GPG_PASSPHRASE=your_strong_passphrase

# (Optional) Email notifications (example for Gmail)
# NOTIFICATION_URLS=smtps://user@gmail.com:password@smtp.gmail.com:465/?fromAddress=sender@gmail.com&toAddresses=you@example.com