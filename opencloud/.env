# OpenCloud domain
OC_DOMAIN=cloud.linuxpad.blog

# Collabora domain
COLLABORA_DOMAIN=collabora.linuxpad.blog

# WOPI server domain
WOPISERVER_DOMAIN=wopiserver.linuxpad.blog

# Initial admin password (required)
INITIAL_ADMIN_PASSWORD=YourSecurePassword

# Disable certificate validation if using self-signed or internal CA
INSECURE=true

# Use external proxy configuration (no Traefik in compose)
COMPOSE_FILE=docker-compose.yml:weboffice/collabora.yml:external-proxy/opencloud.yml:external-proxy/collabora.yml

# Optional: Set log level
LOG_LEVEL=warn

# Optional: Define config and data directories (uncomment and set if not using volumes)
# OC_CONFIG_DIR=/path/to/opencloud/config
# OC_DATA_DIR=/path/to/opencloud/data

# Optional: Use rolling release
# OC_DOCKER_IMAGE=opencloudeu/opencloud-rolling   