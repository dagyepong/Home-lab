# --- Directory Paths ---
# Absolute paths on your host machine
CONFIGDIR=/home/nana/docker/opencloud/config
STUFF=/home/nana/docker/opencloud/data
# If you don't have a 'config' folder yet, create it: mkdir -p /home/nana/docker/opencloud/config /home/nana/docker/opencloud/data

# --- Timezone ---
TZ=Europe/Berlin  # Change to your timezone (e.g., America/New_York)

# --- SMTP Configuration (Notifications) ---
# You can leave these blank if you don't need email notifications yet, 
# but OpenCloud might complain. For testing, you can use dummy values.
NOTIFICATIONS_SMTP_HOST=smtp.gmail.com
NOTIFICATIONS_SMTP_PORT=587
NOTIFICATIONS_SMTP_SENDER=noreply@linuxpad.blog
NOTIFICATIONS_SMTP_USERNAME=your_email@gmail.com
NOTIFICATIONS_SMTP_PASSWORD=your_app_password
OC_NOTIFICATIONS_EMAIL_TEMPLATE_PATH=/etc/opencloud/email-templates

# --- Collabora ---
COLLABORA_ADMIN_PASSWORD=SecureCollaboraPassword123!

# --- PocketID / OpenCloud OIDC ---
# Ensure the Client ID matches your PocketID config
WEB_OIDC_CLIENT_ID=6544440d-2a0b-492b-ba98-xxxxxxx